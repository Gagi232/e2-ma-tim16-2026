<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvGameTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skočko"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary_green"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"/>

        <!-- Tajmer i runda -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvRound"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Runda 1/2"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"/>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/primary_yellow">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ "
                        android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Uputstvo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pogodi kombinaciju od 4 simbola u 6 pokušaja!"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Dostupni simboli -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/white">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dostupni simboli:"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="⬛" android:textSize="24sp" android:gravity="center"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="⬜" android:textSize="24sp" android:gravity="center"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🔴" android:textSize="24sp" android:gravity="center"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="💛" android:textSize="24sp" android:gravity="center"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🔺" android:textSize="24sp" android:gravity="center"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="⭐" android:textSize="24sp" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tačna kombinacija (prikazuje se na kraju) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_green_light">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Tačna kombinacija:"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"
                    android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <TextView android:id="@+id/tvSol1" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="⬛" android:textSize="28sp" android:gravity="center"/>
                    <TextView android:id="@+id/tvSol2" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="🔴" android:textSize="28sp" android:gravity="center"/>
                    <TextView android:id="@+id/tvSol3" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="⭐" android:textSize="28sp" android:gravity="center"/>
                    <TextView android:id="@+id/tvSol4" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="💛" android:textSize="28sp" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 6 Pokušaja -->

        <!-- Pokušaj 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="1." android:textSize="13sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                android:text="0/4 ✓" android:textSize="11sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="2." android:textSize="13sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                android:text="0/4 ✓" android:textSize="11sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="3." android:textSize="13sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                android:text="0/4 ✓" android:textSize="11sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 4 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="4." android:textSize="13sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                android:text="0/4 ✓" android:textSize="11sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 5 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="5." android:textSize="13sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                android:text="0/4 ✓" android:textSize="11sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 6 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="6." android:textSize="13sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginHorizontal="3dp"
                android:gravity="center" android:text="\?" android:textSize="20sp"
                android:background="@color/primary_green_light"/>
            <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                android:text="0/4 ✓" android:textSize="11sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sledeća igra →"
            style="@style/ButtonPrimary"/>

    </LinearLayout>
</ScrollView>