<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Regioni Srbije"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"/>

        <!-- Mapa -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_green_light">
            <org.osmdroid.views.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </androidx.cardview.widget.CardView>

        <!-- Mesečna rang lista -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mesečna rang lista — klikni za statistiku"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/white">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Beograd -->
                <LinearLayout
                    android:id="@+id/rowBeograd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏙️" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Beograd" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:id="@+id/badgeBeograd"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="← Vaš region" android:textSize="11sp"
                            android:textColor="@color/primary_green" android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvBeogradZvezde"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 ⭐" android:textSize="14sp"
                        android:textColor="@color/primary_yellow_dark" android:textStyle="bold"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Vojvodina -->
                <LinearLayout
                    android:id="@+id/rowVojvodina"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌾" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Vojvodina" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:id="@+id/badgeVojvodina"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="← Vaš region" android:textSize="11sp"
                            android:textColor="@color/primary_green" android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvVojvodinaZvezde"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 ⭐" android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Šumadija -->
                <LinearLayout
                    android:id="@+id/rowSumadija"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⛰️" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Šumadija" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:id="@+id/badgeSumadija"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="← Vaš region" android:textSize="11sp"
                            android:textColor="@color/primary_green" android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvSumadijaZvezde"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 ⭐" android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Zapadna Srbija -->
                <LinearLayout
                    android:id="@+id/rowZapadna"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌲" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Zapadna Srbija" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:id="@+id/badgeZapadna"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="← Vaš region" android:textSize="11sp"
                            android:textColor="@color/primary_green" android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvZapadnaZvezde"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 ⭐" android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Istočna Srbija -->
                <LinearLayout
                    android:id="@+id/rowIstocna"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏔️" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Istočna Srbija" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:id="@+id/badgeIstocna"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="← Vaš region" android:textSize="11sp"
                            android:textColor="@color/primary_green" android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvIstocnaZvezde"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 ⭐" android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Južna Srbija -->
                <LinearLayout
                    android:id="@+id/rowJuzna"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌄" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Južna Srbija" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:id="@+id/badgeJuzna"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="← Vaš region" android:textSize="11sp"
                            android:textColor="@color/primary_green" android:textStyle="bold"
                            android:visibility="gone"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvJuznaZvezde"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 ⭐" android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💬 Regionalni čet"
            android:layout_marginTop="16dp"
            style="@style/ButtonPrimary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenChallenges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚔️ Izazovi"
            android:layout_marginTop="8dp"
            style="@style/ButtonSecondary"/>
    </LinearLayout>
</ScrollView>