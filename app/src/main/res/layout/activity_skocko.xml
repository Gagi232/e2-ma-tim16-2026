<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <include
        android:id="@+id/gameTopBar"
        layout="@layout/include_game_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvGameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Skočko"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/gameTopBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Score bar: Ti / Timer / Protivnik -->
    <LinearLayout
        android:id="@+id/llScoreBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvGameTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_green_light">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="6dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ti"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/tvMyScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_yellow">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_green_light">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="6dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Protivnik"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/tvOpponentScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Runda + simboli u jednom redu -->
    <LinearLayout
        android:id="@+id/llRoundSymbols"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/llScoreBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvRound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Runda 1/2"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="12dp"/>

        <!-- Simboli inline -->
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="⬛" android:textSize="20sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="⬜" android:textSize="20sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🔴" android:textSize="20sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="💛" android:textSize="20sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🔺" android:textSize="20sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="⭐" android:textSize="20sp" android:gravity="center"/>

    </LinearLayout>

    <!-- Svi pokušaji + protivnik — zauzimaju sav slobodan prostor -->
    <LinearLayout
        android:id="@+id/llAllAttempts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:weightSum="8"
        app:layout_constraintTop_toBottomOf="@id/llRoundSymbols"
        app:layout_constraintBottom_toTopOf="@id/llBottomButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Pokušaj 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="1." android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="0/4 ✓" android:textSize="10sp" android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="2." android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="0/4 ✓" android:textSize="10sp" android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="3." android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="0/4 ✓" android:textSize="10sp" android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 4 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="4." android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="0/4 ✓" android:textSize="10sp" android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 5 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="5." android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="0/4 ✓" android:textSize="10sp" android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Pokušaj 6 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="6." android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?" android:textSize="18sp" android:background="@color/primary_green_light"/>
            <TextView android:layout_width="52dp" android:layout_height="wrap_content" android:text="0/4 ✓" android:textSize="10sp" android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <!-- Separator -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#DDDDDD" android:layout_weight="0"
            android:layout_marginBottom="6dp"/>

        <!-- Protivnik -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                android:text="P." android:textSize="12sp" android:textColor="@color/text_secondary"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?"
                android:textSize="18sp" android:background="#F0F0F0"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?"
                android:textSize="18sp" android:background="#F0F0F0"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?"
                android:textSize="18sp" android:background="#F0F0F0"/>
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginHorizontal="2dp" android:gravity="center" android:text="?"
                android:textSize="18sp" android:background="#F0F0F0"/>
            <TextView android:layout_width="52dp" android:layout_height="wrap_content"
                android:text="-- ✓" android:textSize="10sp" android:textColor="@color/text_secondary"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Konačno rešenje — skriveno, prikazuje se iz koda kad igra završi -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSolutionFinal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_green_light">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Konačno rešenje:" android:textSize="11sp"
                    android:textColor="@color/primary_green" android:layout_gravity="center"
                    android:layout_marginBottom="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔴" android:textSize="22sp" android:layout_marginHorizontal="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⭐" android:textSize="22sp" android:layout_marginHorizontal="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔺" android:textSize="22sp" android:layout_marginHorizontal="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⬛" android:textSize="22sp" android:layout_marginHorizontal="6dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/llBottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Napusti igru"
            android:layout_marginEnd="8dp"
            android:textColor="@color/primary_green"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/primary_green"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sledeća igra →"
            style="@style/ButtonPrimary"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>