<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvGameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/moj_broj"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tajmer i runda -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvGameTitle">

        <TextView
            android:id="@+id/tvRunda"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Runda 1"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_yellow">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ "
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintBottom_toTopOf="@id/llActions">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvTrazeniBroj"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/question_mark"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj5"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj6"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilIzraz"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Tvoj izraz"
                app:boxStrokeColor="@color/primary_green"
                app:hintTextColor="@color/primary_green">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etIzraz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <GridLayout
                android:id="@+id/gridTastatura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="4"
                android:rowCount="4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB1"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="B1"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB2"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="B2"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB3"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="B3"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLeftParen"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="("
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB4"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="B4"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB5"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="B5"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB6"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="B6"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRightParen"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text=")"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlus"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="+"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMinus"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="-"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMul"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="×"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDiv"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="÷"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="←"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="C"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="STOP"
                    android:backgroundTint="@color/primary_yellow"
                    android:textColor="@color/text_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPotvrdi"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_columnWeight="1"
                    android:text="✓"
                    android:backgroundTint="@color/primary_green"
                    android:textColor="@color/white" />

            </GridLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/llActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPredaj"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Odustani"
            style="@style/Widget.Material3.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/spojnice_next_game"
            style="@style/ButtonPrimary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
