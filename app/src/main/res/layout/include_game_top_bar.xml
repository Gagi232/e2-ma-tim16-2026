<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/gameTopBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/primary_green"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <!-- Tokeni -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_chip_yellow"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🎟️" android:textSize="13sp"/>
            <TextView android:id="@+id/tvTokens"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="5" android:textColor="@color/text_primary"
                android:textStyle="bold" android:textSize="13sp" android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Zvezde -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_chip_yellow"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⭐" android:textSize="13sp"/>
            <TextView android:id="@+id/tvStars"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="@color/text_primary"
                android:textStyle="bold" android:textSize="13sp" android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Liga -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_chip_yellow"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏆" android:textSize="13sp"/>
            <TextView android:id="@+id/tvLeague"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/league" android:textColor="@color/text_primary"
                android:textStyle="bold" android:textSize="13sp" android:layout_marginStart="4dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>