<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <include
        android:id="@+id/gameTopBar"
        layout="@layout/include_game_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvGameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/moj_broj"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/gameTopBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Score bar: Ti / Timer / Protivnik -->
    <LinearLayout
        android:id="@+id/llScoreBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvGameTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_green_light">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="6dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ti"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/tvMyScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_yellow">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_green_light">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="6dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Protivnik"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/tvOpponentScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
    <ProgressBar
        android:id="@+id/pbTime"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/llScoreBar" />
    <TextView
        android:id="@+id/tvRunda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Runda 1"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="6dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/llScoreBar"
        app:layout_constraintStart_toStartOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvRunda"
        app:layout_constraintBottom_toTopOf="@id/llBottomButtons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Traženi broj -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvTrazeniBroj"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/question_mark"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 6 dostupnih brojeva -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj5"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_margin="3dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/white">
                    <TextView
                        android:id="@+id/tvBroj6"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/question_mark"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Polje za izraz -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilIzraz"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Tvoj izraz"
                app:boxStrokeColor="@color/primary_green"
                app:hintTextColor="@color/primary_green">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etIzraz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tastatura -->
            <GridLayout
                android:id="@+id/gridTastatura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:columnCount="4"
                android:rowCount="4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB1"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="B1"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB2"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="B2"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB3"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="B3"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLeftParen"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="("
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB4"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="B4"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB5"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="B5"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnB6"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="B6"
                    style="@style/Widget.Material3.Button.TonalButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRightParen"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text=")"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlus"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="+"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMinus"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="-"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMul"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="×"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDiv"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="÷"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="←"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="C"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="STOP"
                    android:backgroundTint="@color/primary_yellow"
                    android:textColor="@color/text_primary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPotvrdi"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:text="✓"
                    android:backgroundTint="@color/primary_green"
                    android:textColor="@color/white"/>

            </GridLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/llBottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPredaj"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Napusti igru"
            android:layout_marginEnd="8dp"
            android:textColor="@color/primary_green"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/primary_green"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/spojnice_next_game"
            style="@style/ButtonPrimary"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>