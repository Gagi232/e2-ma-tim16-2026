<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvGameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/spojnice"
        tools:text="Spojnice"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tajmer i runda -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvGameTitle">

        <TextView
            android:id="@+id/tvRound"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Runda 1/2"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"/>

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/primary_yellow">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ "
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/spojnice_timer_value"
                    tools:text="30"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Uputstvo -->
    <TextView
        android:id="@+id/tvInstruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/spojnice_instruction"
        tools:text="Povežite pojmove iz leve i desne kolone"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/llHeader"/>

    <!-- Kolone za spojnice -->
    <LinearLayout
        android:id="@+id/llColumns"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/tvInstruction"
        app:layout_constraintBottom_toTopOf="@id/btnFinish">

        <!-- Leva kolona -->
        <LinearLayout
            android:id="@+id/llLeft"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <TextView
                    android:id="@+id/tvLeft1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_left_1"
                    tools:text="Pojam 1"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <TextView
                    android:id="@+id/tvLeft2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_left_2"
                    tools:text="Pojam 2"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <TextView
                    android:id="@+id/tvLeft3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_left_3"
                    tools:text="Pojam 3"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <TextView
                    android:id="@+id/tvLeft4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_left_4"
                    tools:text="Pojam 4"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <TextView
                    android:id="@+id/tvLeft5"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_left_5"
                    tools:text="Pojam 5"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Desna kolona -->
        <LinearLayout
            android:id="@+id/llRight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/primary_yellow_light">
                <TextView
                    android:id="@+id/tvRight1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_right_1"
                    tools:text="Odgovor 1"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/primary_yellow_light">
                <TextView
                    android:id="@+id/tvRight2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_right_2"
                    tools:text="Odgovor 2"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/primary_yellow_light">
                <TextView
                    android:id="@+id/tvRight3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_right_3"
                    tools:text="Odgovor 3"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/primary_yellow_light">
                <TextView
                    android:id="@+id/tvRight4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_right_4"
                    tools:text="Odgovor 4"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/primary_yellow_light">
                <TextView
                    android:id="@+id/tvRight5"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/spojnice_right_5"
                    tools:text="Odgovor 5"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFinish"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/spojnice_next_game"
        tools:text="Sledeća igra →"
        style="@style/ButtonPrimary"
        app:layout_constraintTop_toBottomOf="@id/llColumns"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>