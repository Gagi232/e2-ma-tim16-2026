<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Naziv regiona -->
    <TextView
        android:id="@+id/tvRegionNaziv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vojvodina"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary_green"
        android:layout_gravity="center"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvZvezde"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="245 ⭐"
        android:textSize="16sp"
        android:textColor="@color/primary_yellow_dark"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Mesta -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@color/primary_yellow_light">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🥇" android:textSize="28sp" android:gravity="center"/>
            <TextView
                android:id="@+id/tvPrvaMesta"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="24sp" android:textStyle="bold"
                android:textColor="@color/gold_border" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1. mesta" android:textSize="11sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="@color/primary_green_light">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🥈" android:textSize="28sp" android:gravity="center"/>
            <TextView
                android:id="@+id/tvDrugaMesta"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="24sp" android:textStyle="bold"
                android:textColor="@color/silver_border" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="2. mesta" android:textSize="11sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@color/primary_green_light">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🥉" android:textSize="28sp" android:gravity="center"/>
            <TextView
                android:id="@+id/tvTrecaMesta"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="24sp" android:textStyle="bold"
                android:textColor="@color/bronze_border" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="3. mesta" android:textSize="11sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/primary_green_light"
        android:layout_marginBottom="16dp"/>

    <!-- Igrači -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🟢" android:textSize="28sp" android:gravity="center"/>
            <TextView
                android:id="@+id/tvAktivnih"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="24sp" android:textStyle="bold"
                android:textColor="@color/correct_answer" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Aktivnih" android:textSize="12sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥" android:textSize="28sp" android:gravity="center"/>
            <TextView
                android:id="@+id/tvRegistrovanih"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="24sp" android:textStyle="bold"
                android:textColor="@color/primary_green" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Registrovanih" android:textSize="12sp"
                android:textColor="@color/text_secondary" android:gravity="center"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>