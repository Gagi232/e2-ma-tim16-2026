<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
    <TextView android:id="@+id/tvCRRank"
        android:layout_width="40dp" android:layout_height="wrap_content"
        android:textSize="20sp" android:gravity="center"/>
    <TextView android:id="@+id/tvCRUsername"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textSize="16sp"/>
    <TextView android:id="@+id/tvCRScore"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/primary_yellow_dark"/>
</LinearLayout>