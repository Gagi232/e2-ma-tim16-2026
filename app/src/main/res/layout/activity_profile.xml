<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Dugme za nazad -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:layout_marginBottom="8dp"
            app:tint="@color/primary_green" />

        <!-- Header kartica -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/primary_green">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <TextView
                        android:id="@+id/ivAvatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:gravity="center"
                        android:textSize="48sp"
                        android:text="👤"
                        android:background="@drawable/bg_avatar"/>
                    <ImageView
                        android:id="@+id/ivChangeAvatar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@color/primary_yellow"
                        android:padding="4dp"
                        android:layout_gravity="bottom|end"/>
                </FrameLayout>

                <!-- Username -->
                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="korisnicko_ime"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>

                <!-- Email -->
                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@email.com"
                    android:textColor="@color/primary_green_light"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <!-- Region i Liga -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tvRegion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Vojvodina"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:background="@drawable/bg_chip_green"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvLeague"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆 Liga 0"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:background="@drawable/bg_chip_yellow"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tokeni i zvezde -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎟️"
                        android:textSize="28sp"/>
                    <TextView
                        android:id="@+id/tvTokens"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_green"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tokeni"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="28sp"/>
                    <TextView
                        android:id="@+id/tvStars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_yellow_dark"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zvezde"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- QR kod -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="QR kod za prijatelje"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
                <ImageView
                    android:id="@+id/ivQrCode"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/baseline_qr_code_24"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Statistika naslov -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statistika"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <!-- Statistika kartice -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Ukupno partija -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Ukupno partija"
                        android:textSize="14sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvTotalGames"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/primary_green"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Procenat pobeda/poraza -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏆 Pobede / Porazi"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:paddingTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginTop="4dp" android:layout_marginBottom="4dp">
                    <ProgressBar android:id="@+id/pbWinRate"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progress="60" android:progressTint="@color/primary_green"/>
                    <TextView android:id="@+id/tvWinRate"
                        android:layout_width="50dp" android:layout_height="wrap_content"
                        android:text="60%" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="@color/primary_green" android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Ko zna zna -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🧠 Ko zna zna — pogođena/promašena pitanja"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:paddingTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginTop="4dp" android:layout_marginBottom="4dp">
                    <ProgressBar android:id="@+id/pbKoZnaZna"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progress="60" android:progressTint="@color/primary_green"/>
                    <TextView android:id="@+id/tvKoZnaZnaStats"
                        android:layout_width="60dp" android:layout_height="wrap_content"
                        android:text="3/2 ✓/✗" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/primary_green" android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvKoZnaZnaAvg"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prosek bodova: 15-20"
                    android:textSize="11sp" android:textColor="@color/text_hint"
                    android:layout_marginBottom="8dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Spojnice -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔗 Spojnice — uspešno povezani pojmovi"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:paddingTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginTop="4dp" android:layout_marginBottom="4dp">
                    <ProgressBar android:id="@+id/pbSpojnice"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progress="45" android:progressTint="@color/primary_yellow_dark"/>
                    <TextView android:id="@+id/tvSpojniceStats"
                        android:layout_width="50dp" android:layout_height="wrap_content"
                        android:text="45%" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="@color/primary_yellow_dark" android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvSpojniceAvg"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prosek bodova: 8-12"
                    android:textSize="11sp" android:textColor="@color/text_hint"
                    android:layout_marginBottom="8dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Asocijacije -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💡 Asocijacije — rešene/nerešene"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:paddingTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginTop="4dp" android:layout_marginBottom="4dp">
                    <ProgressBar android:id="@+id/pbAsocijacije"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progress="70" android:progressTint="@color/primary_green"/>
                    <TextView android:id="@+id/tvAsocijacijeStats"
                        android:layout_width="60dp" android:layout_height="wrap_content"
                        android:text="7/3 ✓/✗" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/primary_green" android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvAsocijacijeAvg"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prosek bodova: 20-30"
                    android:textSize="11sp" android:textColor="@color/text_hint"
                    android:layout_marginBottom="8dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Skočko -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🎯 Skočko — pogođene kombinacije po pokušaju"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:paddingTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginTop="4dp" android:layout_marginBottom="4dp">
                    <ProgressBar android:id="@+id/pbSkocko"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progress="35" android:progressTint="@color/wrong_answer"/>
                    <TextView android:id="@+id/tvSkockoStats"
                        android:layout_width="50dp" android:layout_height="wrap_content"
                        android:text="35%" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="@color/wrong_answer" android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvSkockoAvg"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prosek bodova: 10-15"
                    android:textSize="11sp" android:textColor="@color/text_hint"
                    android:layout_marginBottom="8dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Korak po korak -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👣 Korak po korak — pogođeni pojmovi po koraku"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:paddingTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginTop="4dp" android:layout_marginBottom="4dp">
                    <ProgressBar android:id="@+id/pbKorakPoKorak"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progress="55" android:progressTint="@color/primary_yellow_dark"/>
                    <TextView android:id="@+id/tvKorakStats"
                        android:layout_width="50dp" android:layout_height="wrap_content"
                        android:text="55%" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="@color/primary_yellow_dark" android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvKorakAvg"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prosek bodova: 12-18"
                    android:textSize="11sp" android:textColor="@color/text_hint"
                    android:layout_marginBottom="8dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/primary_green_light"/>

                <!-- Moj broj -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔢 Moj broj — tačan broj pronađen"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:paddingTop="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginTop="4dp" android:layout_marginBottom="4dp">
                    <ProgressBar android:id="@+id/pbMojBroj"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progress="40" android:progressTint="@color/primary_green"/>
                    <TextView android:id="@+id/tvMojBrojStats"
                        android:layout_width="50dp" android:layout_height="wrap_content"
                        android:text="40%" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="@color/primary_green" android:gravity="end"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvMojBrojAvg"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prosek bodova: 5-10"
                    android:textSize="11sp" android:textColor="@color/text_hint"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Logout dugme -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logout"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            style="@style/ButtonSecondary"/>

    </LinearLayout>
</ScrollView>